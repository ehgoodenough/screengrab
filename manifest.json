{
    "manifest_version": 3,
    "name": "Screengrab",
    "version": "1.0",
    "description": "An experimental extension for taking screenshots from videos.",
    "action": {
        "default_icon": "icon.png",
        "default_title": "Screengrab a video"
    },
    "commands": {
        "run-foo": {
            "suggested_key": {
                "default": "Ctrl+Shift+4",
                "mac": "Command+Shift+4"
            },
            "description": "Run \"foo\" on the current page."
        },
        "_execute_action": {
            "suggested_key": {
                "windows": "Ctrl+Shift+3",
                "mac": "Command+Shift+3",
                "chromeos": "Ctrl+Shift+3",
                "linux": "Ctrl+Shift+3"
            }
        }
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "background": {
        "service_worker": "worker.js"
    }
}
